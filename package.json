{
  "name": "hucheck",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun scripts/dev.ts",
    "build": "tsc -b && vite build",
    "lint": "bun run biome:lint && bun run biome:format",
    "preview": "vite preview",
    "prebuild": "cx-audit ./",
    "predeploy": "cx-audit ./",
    "biome:check": "biome check ./src",
    "biome:lint": "biome lint ./src --diagnostic-level=error",
    "biome:format": "biome format ./src --diagnostic-level=error",
    "biome:fix": "biome check --write ./src",
    "lint-fix": "biome check --write ./src"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@tanstack/react-query": "^5",
    "axios": "^0.27.2",
    "dotenv": "^17.4.2",
    "hu-translations": "npm:@humanddev/hu-translations@latest",
    "i18next": "^21.3.1",
    "idb": "^8.0.3",
    "material-hu": "npm:@humanddev/material-hu@latest",
    "qs": "^6.15.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "7.54.2",
    "react-i18next": "^11.13.0",
    "react-router-dom": "^6.26.2",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "@humanddev/external-app-audit": "^0.1.0",
    "@types/node": "^24.12.3",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "humand-biome-config": "npm:@humanddev/humand-biome-config@latest",
    "typescript": "~6.0.2",
    "vercel": "^54.2.0",
    "vite": "^8.0.12"
  }
}
